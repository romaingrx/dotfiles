{ lib }:
let
  renderColors =
    theme:
    let
      f = theme.format;
      p = theme.palette;
      t = theme.roles.ui;
      s = theme.roles.status;
      lines = [
        [
          "BLACK"
          (f.argb t.backgroundStrong "ff")
        ]
        [
          "WHITE"
          (f.argb t.foreground "ff")
        ]
        [
          "RED"
          (f.argb s.danger "ff")
        ]
        [
          "GREEN"
          (f.argb s.success "ff")
        ]
        [
          "BLUE"
          (f.argb s.info "ff")
        ]
        [
          "YELLOW"
          (f.argb s.warning "ff")
        ]
        [
          "ORANGE"
          (f.argb p.peach "ff")
        ]
        [
          "MAGENTA"
          (f.argb t.accent "ff")
        ]
        [
          "GREY"
          (f.argb p.overlay2 "ff")
        ]
        [
          "TRANSPARENT"
          "0x00000000"
        ]
        [
          "BAR_BG"
          (f.argb t.background "15")
        ]
        [
          "STATUS_BG"
          (f.argb t.background "22")
        ]
        [
          "STATUS_GRAPH_BG"
          (f.argb t.background "16")
        ]
        [
          "POPUP_BG"
          (f.argb t.background "70")
        ]
        [
          "SPACE_INITIAL_BG"
          (f.argb t.foreground "44")
        ]
        [
          "SPACE_FOCUSED_BG"
          (f.argb t.foreground "55")
        ]
        [
          "SPACE_VISIBLE_BG"
          (f.argb t.foreground "22")
        ]
        [
          "MODE_BG"
          (f.argb t.accent "24")
        ]
        [
          "CPU_SYSTEM_FILL"
          (f.argb s.danger "20")
        ]
        [
          "CPU_USER_FILL"
          (f.argb s.info "20")
        ]
        [
          "NET_DOWNLOAD_FILL"
          (f.argb s.info "20")
        ]
        [
          "NET_UPLOAD_FILL"
          (f.argb s.success "20")
        ]
        [
          "DEFAULT_ICON_COLOR"
          (f.argb t.foreground "ff")
        ]
        [
          "DEFAULT_LABEL_COLOR"
          (f.argb t.foreground "ff")
        ]
      ];
    in
    lib.concatStringsSep "\n" (
      [ "# Generated by Home Manager; source config/sketchybar/colors.sh instead." ]
      ++ map (line: "${builtins.elemAt line 0}=${builtins.elemAt line 1}") lines
    );
in
{
  colors = theme: renderColors theme + "\n";
}
