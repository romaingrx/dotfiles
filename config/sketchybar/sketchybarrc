#!/usr/bin/env bash

if [ -z "${CONFIG_DIR:-}" ] || [ ! -r "$CONFIG_DIR/colors.sh" ]; then
	CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi
PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"
HELPER_DIR="$CONFIG_DIR/helpers"

source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/icons.sh"

export FONT="IBM Plex Mono"
export NERD_FONT="JetBrainsMono Nerd Font"
export APP_FONT="sketchybar-app-font"
export STATUS_BG=0x22000000
export STATUS_GRAPH_BG=0x16000000
export STATUS_RADIUS=6
export STATUS_HEIGHT=22
export STATUS_GRAPH_WIDTH=42
export STATUS_GRAPH_HEIGHT="$STATUS_HEIGHT"
export STATUS_GRAPH_LABEL_WIDTH=34
export CONFIG_DIR PLUGIN_DIR ITEM_DIR HELPER_DIR FONT NERD_FONT APP_FONT
export STATUS_BG STATUS_GRAPH_BG STATUS_RADIUS STATUS_HEIGHT
export STATUS_GRAPH_WIDTH STATUS_GRAPH_HEIGHT STATUS_GRAPH_LABEL_WIDTH

if [ -n "${SKETCHYBAR_APP_FONT_PATH:-}" ] && [ -r "$SKETCHYBAR_APP_FONT_PATH" ]; then
	sketchybar --load-font "$SKETCHYBAR_APP_FONT_PATH"
fi

sketchybar --bar height=30 \
	blur_radius=100 \
	position=top \
	padding_left=10 \
	padding_right=10 \
	color=0x15000000 \
	shadow=on

sketchybar --default updates=when_shown \
	drawing=on \
	icon.font="$NERD_FONT:Regular:14.0" \
	icon.color=0xffffffff \
	label.font="$FONT:Medium:14.0" \
	label.color=0xffffffff \
	label.padding_left=4 \
	label.padding_right=4 \
	icon.padding_left=4 \
	icon.padding_right=4

source $ITEM_DIR/apple.sh
source $ITEM_DIR/display_recovery.sh
source $ITEM_DIR/spaces.sh
source $ITEM_DIR/mode.sh
source $ITEM_DIR/window_title.sh
source $ITEM_DIR/clock.sh
source $ITEM_DIR/battery.sh
source $ITEM_DIR/cpu.sh
source $ITEM_DIR/wifi.sh

sketchybar --update

echo "sketchybar configuration loaded.."
